font_size 15.0
disable_ligatures always
scrollback_lines 200000
enable_audio_bell no
shell /usr/bin/fish

cursor none
cursor_text_color background

tab_bar_style           separator
tab_switch_strategy     right
tab_separator           "  "
tab_bar_background      #{{ .colors.dark1 }}
active_tab_foreground   #{{ .colors.bright_aqua }}
active_tab_background   #{{ .colors.dark1 }}
active_tab_font_style   normal
inactive_tab_foreground #{{ .colors.dark4 }}
inactive_tab_background #{{ .colors.dark1 }}
inactive_tab_font_style normal

foreground            #{{ .colors.light1 }}
background            #{{ .colors.dark0_hard }}
selection_foreground  none
selection_background  #{{ .colors.dark3 }}
color0                #{{ .colors.dark3 }}
color8                #{{ .colors.gray }}
color1                #{{ .colors.neutral_red }}
color9                #{{ .colors.bright_red }}
color2                #{{ .colors.neutral_green }}
color10               #{{ .colors.bright_green }}
color3                #{{ .colors.neutral_yellow }}
color11               #{{ .colors.bright_yellow }}
color4                #{{ .colors.neutral_blue }}
color12               #{{ .colors.bright_blue }}
color5                #{{ .colors.neutral_purple }}
color13               #{{ .colors.bright_purple }}
color6                #{{ .colors.neutral_aqua }}
color14               #{{ .colors.bright_aqua }}
color7                #{{ .colors.light1 }}
color15               #{{ .colors.light0_hard }}
url_color             #{{ .colors.light1 }}
active_border_color   #{{ .colors.bright_orange }}
inactive_border_color #{{ .colors.dark1 }}
bell_border_color     #{{ .colors.bright_red }}
mark1_foreground      #{{ .colors.dark0_hard }}
mark1_background      #{{ .colors.bright_yellow }}
mark2_foreground      #{{ .colors.dark0_hard }}
mark2_background      #{{ .colors.bright_orange }}
mark3_foreground      #{{ .colors.dark0_hard }}
mark3_background      #{{ .colors.bright_purple }}

map kitty_mod+] next_tab
map kitty_mod+[ previous_tab
map --when-focus-on var:in_editor kitty_mod+/
map --when-focus-on var:in_editor kitty_mod+h
mouse_map left click ungrabbed mouse_handle_click selection prompt
